# Observability Backend environment Variables
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=senhaforte
TRAEFIK_DOMAIN=grafana.seudominio.com.br

# SMTP do Grafana - obrigatórias para habilitar envio de e-mail

# Habilita o envio de e-mails pelo Grafana.
GF_SMTP_ENABLED=false

# Endereco do servidor SMTP no formato host:porta.
GF_SMTP_HOST=

# Endereco de e-mail remetente exibido nas mensagens enviadas.
GF_SMTP_FROM_ADDRESS=admin@seudominio.com.br

# SMTP do Grafana - opcionais conforme o provedor

# Usuario para autenticacao SMTP. Preencha se o servidor exigir login.
GF_SMTP_USER=

# Senha para autenticacao SMTP. Preencha se o servidor exigir login.
GF_SMTP_PASSWORD=

# Nome amigavel do remetente exibido no e-mail.
GF_SMTP_FROM_NAME=Grafana

# Ignora a verificacao do certificado TLS do servidor SMTP.
GF_SMTP_SKIP_VERIFY=false

# Identidade enviada no comando EHLO durante a conexao SMTP.
GF_SMTP_EHLO_IDENTITY=

# Politica de STARTTLS: OpportunisticStartTLS, MandatoryStartTLS ou NoStartTLS.
GF_SMTP_STARTTLS_POLICY=

# Caminho para arquivo de certificado cliente, se o SMTP exigir mTLS.
GF_SMTP_CERT_FILE=

# Caminho para chave privada do certificado cliente, se o SMTP exigir mTLS.
GF_SMTP_KEY_FILE=

# Propaga headers de tracing nos e-mails; requer tracing configurado no Grafana.
GF_SMTP_ENABLE_TRACING=false

GRAFANA_LOKI_DATASOURCE_URL=http://loki:3100
GRAFANA_PROMETHEUS_DATASOURCE_URL=http://prometheus:9090
TEMPO_QUERY_API=http://tempo:3200
GRAFANA_BASIC_AUTH_ENABLED=false
GRAFANA_BASIC_AUTH_USERNAME=
GRAFANA_BASIC_AUTH_PASSWORD=

# Colector OpenTelemetry environment Variables]
ALLOY_PROFILE=full
LOKI_URL=https://loki.jiffy.run/loki/api/v1/push
PROMETHEUS_URL=https://prometheus.jiffy.run/api/v1/write
TEMPO_INGEST_OTLP=https://tempo.jiffy.run

OBSERVABILITY_BASIC_AUTH_USERNAME=alloy
OBSERVABILITY_BASIC_AUTH_PASSWORD=super-seguro-aqui
ENVIRONMENT=HOMOLOGACAO
HOST_SERVER_NAME=servidor-01
